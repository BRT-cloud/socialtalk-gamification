rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string
    //   - exp: number (required)
    //   - level: number (required)
    //   - badges: list (strings)
    //   - stats: map (cognitive, emotional, behavioral)
    //
    // Collection: scenarios
    // Document ID: {scenarioId}
    // Fields:
    //   - id: string (required)
    //   - world: string (forest, sea, city, castle)
    //   - stage: number
    //   - isBoss: bool
    //   - title: string
    //   - situation: string
    //   - mediaUrl: string
    //   - difficulty: string
    //
    // Collection: attempts
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required)
    //   - scenarioId: string (required)
    //   - userInput: string (required)
    //   - aiFeedback: string
    //   - scores: map (clarity, sincerity)
    //   - timestamp: timestamp
    //
    // Collection: schoolping
    // Document ID: {missionId}
    // Fields:
    //   - id: string
    //   - title: string
    //   - description: string
    //   - submissions: list of maps (uid, userName, imageUrl, timestamp)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "reuben119@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'exp', 'level', 'wisdom', 'clearedWorlds']) &&
             data.uid is string &&
             data.exp is number &&
             data.level is number &&
             data.wisdom is number &&
             data.clearedWorlds is list &&
             (!('competenceIndex' in data) || data.competenceIndex is number) &&
             (!('schoolpingCompleted' in data) || data.schoolpingCompleted is bool) &&
             (!('badges' in data) || data.badges is list) &&
             (!('stats' in data) || data.stats is map);
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['uid', 'scenarioId', 'questId', 'userInput', 'isCorrect', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.scenarioId is string &&
             data.questId is string &&
             data.userInput is string &&
             data.userInput.size() < 2000 &&
             data.isCorrect is bool;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.get('role', 'student') == 'student' || 
                     (request.auth.token.email == "reuben119@gmail.com" && request.auth.token.email_verified == true && request.resource.data.role == 'admin'));
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && 
                        request.resource.data.get('role', 'student') == resource.data.get('role', 'student')) || 
                    isAdmin();
    }

    match /scenarios/{scenarioId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /attempts/{attemptId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidAttempt(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /schoolping/{missionId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['submissions'])));
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
